{{- $lang             := "en"                           -}}
{{- $headName         := "Name"                         -}}
{{- $headSize         := "Size"                         -}}
{{- $headLastModified := "Last Modified"                -}}

{{- range .Languages                                    -}}
{{-     if eq .Lang "ar"                                -}}
{{-         $lang             = "ar"                    -}}
{{-         $headName         = "الاسم"                 -}}
{{-         $headSize         = "الحجم"                 -}}
{{-         $headLastModified = "آخر تعديل"             -}}
{{-         break                                       -}}
{{-     else if eq .Lang "de"                           -}}
{{-         $lang             = "de"                    -}}
{{-         $headName         = "Name"                  -}}
{{-         $headSize         = "Größe"                 -}}
{{-         $headLastModified = "Letzte Änderung"       -}}
{{-         break                                       -}}
{{-     else if eq .Lang "es"                           -}}
{{-         $lang             = "es"                    -}}
{{-         $headName         = "Nombre"                -}}
{{-         $headSize         = "Tamaño"                -}}
{{-         $headLastModified = "Última modificación"   -}}
{{-         break                                       -}}
{{-     else if eq .Lang "fr"                           -}}
{{-         $lang             = "fr"                    -}}
{{-         $headName         = "Nom"                   -}}
{{-         $headSize         = "Taille"                -}}
{{-         $headLastModified = "Dernière modification" -}}
{{-         break                                       -}}
{{-     else if eq .Lang "hi"                           -}}
{{-         $lang             = "hi"                    -}}
{{-         $headName         = "नाम"                   -}}
{{-         $headSize         = "आकार"                  -}}
{{-         $headLastModified = "अंतिम परिवर्तन"        -}}
{{-         break                                       -}}
{{-     else if eq .Lang "ja"                           -}}
{{-         $lang             = "ja"                    -}}
{{-         $headName         = "名前"                    -}}
{{-         $headSize         = "サイズ"                   -}}
{{-         $headLastModified = "最終更新日時"                -}}
{{-         break                                       -}}
{{-     else if eq .Lang "pt"                           -}}
{{-         $lang             = "pt"                    -}}
{{-         $headName         = "Nome"                  -}}
{{-         $headSize         = "Tamanho"               -}}
{{-         $headLastModified = "Última modificação"    -}}
{{-         break                                       -}}
{{-     else if eq .Lang "ru"                           -}}
{{-         $lang             = "ru"                    -}}
{{-         $headName         = "Имя"                   -}}
{{-         $headSize         = "Размер"                -}}
{{-         $headLastModified = "Дата изменения"        -}}
{{-         break                                       -}}
{{-     else if eq .Lang "zh"                           -}}
{{-         $lang             = "zh"                    -}}
{{-         $headName         = "名称"                    -}}
{{-         $headSize         = "大小"                    -}}
{{-         $headLastModified = "最后修改"                  -}}
{{-         break                                       -}}
{{-     end                                             -}}
{{- end                                                 -}}

<!DOCTYPE html>
<html lang="{{ $lang }}">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width,initial-scale=1">
	<meta name="robots" content="noindex">

	<style>
		{{/* align second column (size) to the right, let heading untouched */ -}}
		table.directoryListing td:nth-child(2) {
			text-align: right;
			padding-right: 1em;
		}
	</style>

	<title> {{.DirectoryName}} </title>
</head>
<body>
	<h1> &#128194; {{.DirectoryName}} </h1>
	<table class="directoryListing" style="font-family: monospace;">
		<thead>
			<tr><th> {{ $headName }} </th><th> {{ $headSize }} </th><th> {{ $headLastModified }} </th></tr>
		</thead>
		<tbody>
			{{- if .ParentDirectory }}
			<tr><td><a href="{{ .ParentDirectory }}"> .. </a></td><td></td><td></td></tr>
			{{- end -}}
			{{- $dirPrefix := .DirectoryPrefix -}}
			{{- range .Entries -}}
			{{- $fi := .Info }}
			<tr>{{ if $fi.IsDir -}}	<td><em><a href="{{ $dirPrefix }}/{{ .Name }}"> &#128193; {{ .Name }}/ </a></em></td>
				{{- else if gt (len .LinkTarget) 0 -}}
				    {{- if eq (slice .LinkTarget 0 1) "/" -}}
									<td><a href="{{ .LinkTarget }}"> &#128279; {{ .Name }} &rarr; {{ .LinkTarget }} </a></td>
					{{- else -}}
									<td><a href="{{ $dirPrefix }}/{{ .Name }}"> &#128279; {{ .Name }} &rarr; {{ .LinkTarget }} </a></td>
					{{- end -}}
				{{- else -}}		<td><a href="{{ $dirPrefix }}/{{ .Name }}"> &#128196; {{ .Name }} </a></td>
				{{- end }}
				<td> {{ $fi.Size    }} </td>
				<td> {{ $fi.ModTime.Format "2006-01-02 15:04:05 -07" }} </td>
			</tr>
			{{- end }}
		</tbody>
	</table>
</body>
</html>